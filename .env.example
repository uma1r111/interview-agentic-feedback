# =============================================================================
# .env.example  —  safe to commit, contains NO real secrets
# =============================================================================
# Copy to .env and fill in real values:
#   cp .env.example .env
# =============================================================================

# ── Azure OpenAI (required) ───────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=<your-azure-openai-api-key>
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com/
OPENAI_API_VERSION=2024-05-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=gpt-4o-mini

# ── PostgreSQL (used by docker-compose; change password before deploying) ─────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=interview_db

# ── Redis ─────────────────────────────────────────────────────────────────────
# Inside Docker network use the service name:  redis://redis_cache:6379/0
# For local dev outside Docker use:            redis://localhost:6379/0
# Leave empty to disable Redis (app degrades gracefully)
REDIS_URL=redis://redis_cache:6379/0

# ── Frontend ──────────────────────────────────────────────────────────────────
# Baked into the Next.js bundle at build time.
# Local Docker:  http://localhost:8000
# Production:    https://your-api-domain.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated, no spaces. Add your frontend URL here.
# Local:  http://localhost:3000,http://frontend:3000
# Azure:  https://platform-frontend.livelybay-74bfa788.centralus.azurecontainerapps.io
ALLOWED_ORIGINS=http://localhost:3000,http://frontend:3000

# ── App tuning (optional) ─────────────────────────────────────────────────────
LLM_TEMPERATURE=0.0
TOKEN_ALERT_THRESHOLD=80000
